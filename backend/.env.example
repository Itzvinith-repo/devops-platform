# Flask environment (development, production, or testing)
# Default to production for security
FLASK_ENV=production

# Secret key for session management and CSRF protection
# REQUIRED in production! Generate a strong random key
# Example: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-strong-secret-key-change-this-in-production

# Database URL
DATABASE_URL=sqlite:///devops_platform.db

# CORS allowed origins (comma-separated)
# In production, set specific frontend URLs
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: Maximum file upload size in MB (default: 50)
# MAX_UPLOAD_SIZE_MB=50

# Optional: Debug mode (only for development)
# DEBUG=False

